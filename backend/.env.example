# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
MONGO_URI=mongodb://127.0.0.1:27017/urbanml

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
ADMIN_SECRET=your-admin-registration-secret-key

# Python Path (for AI models)
PYTHON_PATH=C:\Users\sangr\AppData\Local\Programs\Python\Python313\python.exe

# AI Chatbot APIs (Optional - at least one recommended)
GROQ_API_KEY=your-groq-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
TOGETHER_API_KEY=your-together-api-key

# Email Service (Nodemailer)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# SMS Service (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Redis (for Background Jobs - Optional)
REDIS_URL=redis://localhost:6379
# OR
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# NSFW Detection (Optional - set to 'true' to skip)
NSFW_SKIP=false

# Google Maps API (Optional - for geolocation features)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
